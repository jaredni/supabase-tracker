FROM node:20

WORKDIR /app

# Copy package files first for better caching
COPY package.json package-lock.json ./

# Install dependencies
RUN npm install

# Copy the rest of the app
COPY . .

# Expose port
EXPOSE 3000

# Run dev server
CMD ["npx", "next", "dev", "--hostname", "0.0.0.0", "--port", "3000", "--webpack"]
